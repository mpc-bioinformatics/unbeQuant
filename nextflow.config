// ============================================================================
// Docker Configuration
// ============================================================================
docker.enabled = true

// ============================================================================
// Nextflow Runtime Configuration
// ============================================================================
// Use a clean work directory for each run to prevent contamination
workDir = "${launchDir}/work"

// Keep temporary files during execution but clean on completion
cleanup = false

// ============================================================================
// Process Configuration
// ============================================================================
process {
    // IMPORTANT: Do NOT use scratch mode with -resume, it breaks caching
    // scratch = true is disabled to allow proper work directory caching
    // Work files are preserved in ${launchDir}/work/ directory
    
    // Ensure processes don't share intermediate files
    errorStrategy = 'terminate'
    
    // Standard resource defaults
    cpus = 2
    memory = '4G'
    
    // Process-specific configurations
    withName: 'process_mzml_file' {
        memory = '8G'
        cpus = 2
    }
    
    withName: 'create_heatmap_image' {
        memory = '16G'
        cpus = 2
    }
    
    withName: 'extract_feature_data' {
        memory = '8G'
        cpus = 2
    }
    
    withName: 'pair_features' {
        memory = '12G'
        cpus = 4
    }
    
    withName: 'feature_pairing_report' {
        memory = '8G'
        cpus = 2
    }
    
    withName: 'build_network_graph_visualization' {
        memory = '12G'
        cpus = 4
    }
    
    // Quantification and alignment processes - demanding memory requirements
    withName: 'generate_feature_ident_intesity_table' {
        memory = '16G'
        cpus = 4
    }
    
    withName: 'generate_xlsx_reports_from_tables' {
        memory = '8G'
        cpus = 2
    }
    
    withName: 'generate_plots_from_tables' {
        memory = '8G'
        cpus = 2
    }
}

// ============================================================================
// Execution Configuration
// ============================================================================
executor {
    queueSize = 10
    pollInterval = '30 sec'
}

// ============================================================================
// Output Handling Configuration
// ============================================================================
// Resume-safe configuration
maxRetries = 2
maxErrors = 5

// ============================================================================
// Logging Configuration
// ============================================================================
trace {
    enabled = true
    file = 'trace.txt'
    fields = 'task_id,name,status,exit,submit,start,complete,duration,realtime,cpus,memory'
}

report {
    enabled = true
    file = 'report.html'
}

timeline {
    enabled = true
    file = 'timeline.html'
}