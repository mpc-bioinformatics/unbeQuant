// ============================================================================
// Docker Configuration
// ============================================================================
docker.enabled = true

// ============================================================================
// Nextflow Runtime Configuration
// ============================================================================
// Use a clean work directory for each run to prevent contamination
workDir = "${launchDir}/work"

// Keep temporary files during execution but clean on completion
cleanup = false

// ============================================================================
// Process Configuration
// ============================================================================
process {
    // IMPORTANT: Do NOT use scratch mode with -resume, it breaks caching
    // scratch = true is disabled to allow proper work directory caching
    // Work files are preserved in ${launchDir}/work/ directory
    
    // Ensure processes don't share intermediate files
    errorStrategy = 'terminate'
        

    resourceLimits = [
        memory: 25.GB,
        cpus: 15,
    ]
    // Process-specific configurations

}    
   
// ============================================================================
// Execution Configuration
// ============================================================================
executor {
    //queueSize = 1            // Reduced to prevent memory buildup (high-memory processes like Comet can't run 10 in parallel)
    pollInterval = '15 sec' // Check more frequently for faster feedback
}

// Memory management - prevent WSL from ballooning to 23GB
// If you experience memory issues:
//   1. Reduce queueSize further (2-3 is safer on WSL)
//   2. Run: bash preventative_maintenance.sh
//   3. Restart WSL: wsl --shutdown (from Windows PowerShell Admin)

// ============================================================================
// Output Handling Configuration
// ============================================================================
// Resume-safe configuration
maxRetries = 2
maxErrors = 5

// ============================================================================
// Logging Configuration
// ============================================================================
trace {
    enabled = true
    file = 'trace.txt'
    fields = 'task_id,name,status,exit,submit,start,complete,duration,realtime,cpus,memory'
    overwrite = true
}

report {
    enabled = true
    file = 'report.html'
}

timeline {
    enabled = true
    file = 'timeline.html'
}