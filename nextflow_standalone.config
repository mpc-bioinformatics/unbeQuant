// ============================================================================
// Nextflow Standalone Config for map_mzml_features.nf
// ============================================================================
// Use this config when running map_mzml_features.nf as a standalone workflow:
//   nextflow run map_mzml_features.nf -c nextflow_standalone.config ...
//
// Note: You may see warnings about unmatched process selectors 
// (generate_feature_ident_intesity_table, etc.) - these are harmless and occur
// because both this config and nextflow.config are loaded. Those processes
// only exist in the full pipeline (main_unbequant.nf).
//
// ============================================================================
// Docker Configuration
// ============================================================================
docker.enabled = false

// ============================================================================
// Nextflow Runtime Configuration
// ============================================================================
// Use a clean work directory for each run to prevent contamination
workDir = "${launchDir}/work"

// Keep temporary files during execution but clean on completion
cleanup = false

// ============================================================================
// Process Configuration
// ============================================================================
process {
    // IMPORTANT: Do NOT use scratch mode with -resume, it breaks caching
    // scratch = true is disabled to allow proper work directory caching
    // Work files are preserved in ${launchDir}/work/ directory
    
    // Ensure processes don't share intermediate files
    errorStrategy = 'terminate'
    
    // Standard resource defaults
    cpus = 2
    memory = '4G'
    
    // Process-specific configurations
    withName: 'process_mzml_file' {
        memory = '8G'
        cpus = 2
    }
    
    withName: 'create_heatmap_image' {
        memory = '16G'
        cpus = 2
    }
    
    withName: 'extract_feature_data' {
        memory = '8G'
        cpus = 2
    }
    
    withName: 'pair_features' {
        memory = '12G'
        cpus = 4
    }
    
    withName: 'feature_pairing_report' {
        memory = '8G'
        cpus = 2
    }
    
    withName: 'build_network_graph_visualization' {
        memory = '12G'
        cpus = 15
    }
}

// ============================================================================
// Execution Configuration
// ============================================================================
executor {
    queueSize = 3           // Reduced from 10 to prevent memory buildup
    pollInterval = '15 sec' // Check more frequently for faster feedback
}

// Memory management - prevent WSL from ballooning to 23GB
// If you experience memory issues:
//   1. Reduce queueSize further (2-3 is safer on WSL)
//   2. Run: bash preventative_maintenance.sh
//   3. Restart WSL: wsl --shutdown (from Windows PowerShell Admin)

// ============================================================================
// Output Handling Configuration
// ============================================================================
// Resume-safe configuration
maxRetries = 2
maxErrors = 5

// ============================================================================
// Logging Configuration
// ============================================================================
trace {
    enabled = true
    file = 'trace.txt'
    fields = 'task_id,name,status,exit,submit,start,complete,duration,realtime,cpus,memory'
    overwrite = true
}

report {
    enabled = true
    file = 'report.html'
    overwrite = true
}

timeline {
    enabled = true
    file = 'timeline.html'
    overwrite = true
}
